{
  "name": "choros",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:map && npm run build:sitemap && tsc -b && vite build",
